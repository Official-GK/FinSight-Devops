{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Financial Risk Analytics Platform — Executive DR Dashboard",
  "uid": "financial-risk-executive",
  "description": "Real-time monitoring of the Financial Risk Platform. Shows HPA autoscaling, risk score distribution, service latency, and error rates. Use this dashboard during disaster recovery demonstrations.",
  "tags": ["financial-risk", "hpa", "autoscaling", "executive"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "🔥 Live HPA Replica Count — Analytics API",
      "description": "Shows real-time pod scaling events. Watch this climb during the DR load test.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"financial-risk\",horizontalpodautoscaler=\"analytics-api-hpa\"}",
        "legendFormat": "Current Replicas"
      }],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 9 }
            ]
          },
          "min": 0,
          "max": 10,
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "🔥 Live HPA Replica Count — Risk Engine",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"financial-risk\",horizontalpodautoscaler=\"risk-engine-hpa\"}",
        "legendFormat": "Risk Engine Replicas"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 6 },
              { "color": "red", "value": 9 }
            ]
          },
          "min": 0, "max": 10, "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "title": "📊 Request Rate (req/sec)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "sum(rate(analytics_api_requests_total[1m]))",
        "legendFormat": "Requests/sec"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "🚨 Error Rate (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "100 * sum(rate(analytics_api_requests_total{http_status=~\"5..\"}[5m])) / sum(rate(analytics_api_requests_total[5m]))",
        "legendFormat": "Error Rate %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "📈 HPA Scaling History — Analytics API (Replicas over Time)",
      "description": "Time series showing how HPA scaled pods in response to CPU pressure during the DR test.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"financial-risk\",horizontalpodautoscaler=\"analytics-api-hpa\"}",
          "legendFormat": "Current Replicas"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_min_replicas{namespace=\"financial-risk\",horizontalpodautoscaler=\"analytics-api-hpa\"}",
          "legendFormat": "Min Replicas"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace=\"financial-risk\",horizontalpodautoscaler=\"analytics-api-hpa\"}",
          "legendFormat": "Max Replicas"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 6,
      "title": "⚡ CPU Utilization per Pod (%) — Target: 70%",
      "description": "When any pod crosses 70%, HPA triggers a scale-up event.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"financial-risk\",container!=\"\"}[2m]) * 100",
          "legendFormat": "{{ pod }}"
        },
        {
          "expr": "vector(70)",
          "legendFormat": "HPA Scale-Up Threshold (70%)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    },
    {
      "id": 7,
      "title": "🎯 Risk Score Distribution (Histogram)",
      "description": "Distribution of calculated risk scores. Shows platform health and transaction risk profile.",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "sum by (le) (analytics_api_risk_score_distribution_bucket)",
        "legendFormat": "Risk Score",
        "format": "heatmap"
      }]
    },
    {
      "id": 8,
      "title": "⏱️ API Latency Percentiles (P50/P95/P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(analytics_api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P50 (Median)"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(analytics_api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(analytics_api_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 9,
      "title": "🏦 Transactions by Risk Level",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "sum by (risk_level) (analytics_api_transactions_analyzed_total)",
        "legendFormat": "{{ risk_level }}"
      }],
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },
    {
      "id": 10,
      "title": "📡 Risk Engine Call Latency (P95)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le) (rate(analytics_api_risk_engine_call_duration_seconds_bucket[5m])))",
        "legendFormat": "P95 Latency"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "min": 0,
          "max": 10
        }
      }
    },
    {
      "id": 11,
      "title": "📉 Risk Engine Calculation Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "sum by (transaction_type) (rate(risk_engine_calculations_total[1m]))",
        "legendFormat": "{{ transaction_type }}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 12,
      "title": "🌡️ Market Volatility Factor (Live)",
      "description": "The current market volatility factor applied in risk calculations. Spikes here will cascade to higher risk scores.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 28 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "risk_engine_market_volatility_factor",
        "legendFormat": "Volatility Factor — Pod {{ kubernetes_pod_name }}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 6 }
      }
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
